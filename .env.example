# Optional defaults. The app can also be configured entirely from the built-in setup flow.

VPS_HOST=
VPS_PORT=22
VPS_USER=
VPS_PASSWORD=
# Alternative SSH auth:
# VPS_PRIVATE_KEY_PATH=C:/Users/your-user/.ssh/id_ed25519
# VPS_PRIVATE_KEY_PASSPHRASE=

OPENCLAW_PROFILE=nuevo
OPENCLAW_BINARY_PATH=openclaw
OPENCLAW_STATE_ROOT=/root/.openclaw-nuevo
OPENCLAW_WORKSPACE_ROOT=/root/.openclaw-nuevo/workspace

# Optional default model/provider used as initial suggestions in setup.
OPENCLAW_DEFAULT_PROVIDER=openrouter
OPENCLAW_DEFAULT_MODEL_ID=google/gemini-2.5-pro
OPENCLAW_DEFAULT_MODEL=openrouter/google/gemini-2.5-pro

# Optional provider keys if you want local defaults instead of entering them in setup.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
OPENCLAW_BASE_URL=
